@model List<List<HtmlToPdfWeb.Controllers.ReportController.Row>>
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <style>
    @@page {
      size: A4;
      margin: 0;
    }

    body {
      margin: 0;
      padding: 0;
      font-family: sans-serif;
    }

    .page {
      width: 210mm;
      height: 297mm;
      page-break-after: always;
      position: relative;
      box-sizing: border-box;
      padding: 80px 40px 60px 40px;
    }

    .header, .footer {
      position: absolute;
      left: 0;
      right: 0;
      text-align: center;
      font-size: 12px;
      color: gray;
    }

    .header {
      top: 20px;
    }

    .footer {
      bottom: 20px;
    }

    .content {
      margin-top: 60px;
      margin-bottom: 40px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
    }

    th, td {
      border: 1px solid #ccc;
      padding: 6px;
      font-size: 12px;
    }
  </style>
</head>
<body>

@{
    int totalPages = Model.Count;
    int pageNumber = 1;
    foreach (var table in Model)
    {
<div class="page">
  <div class="header">
    <img src="/logo.png" style="height: 40px;" />
  </div>

  <div class="content">
    <h2>Tabelle @pageNumber</h2>
    <table>
      <tr><th>Spalte 1</th><th>Spalte 2</th><th>Spalte 3</th><th>Spalte 4</th></tr>
      @foreach (var row in table)
      {
          <tr>
              <td>@row.Col1</td>
              <td>@row.Col2</td>
              <td>@row.Col3</td>
              <td>@row.Col4</td>
          </tr>
      }
    </table>
  </div>

  <div class="footer">
    Seite @pageNumber von @totalPages
  </div>
</div>
    pageNumber++;
    }
}
</body>
</html>